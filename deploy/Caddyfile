hyper-gpt.com, www.hyper-gpt.com {
	encode gzip

	# `route` evaluates its directives in written order (rather than Caddy's
	# implicit directive ordering), so basic_auth is GUARANTEED to run before
	# any routing/serving below. This is the only gate in front of the app,
	# so we make the ordering explicit rather than relying on defaults.
	route {
		# Single shared password — one-user app. Hash comes from
		# /etc/caddy/env (HYPERGPT_PASSWORD_HASH), set on first boot.
		# Username is "hyper". Runs on every request; 401s unauthenticated
		# ones before they reach the API or static files.
		basic_auth {
			hyper {$HYPERGPT_PASSWORD_HASH}
		}

		# API + SSE stream → the Bun backend. flush_interval -1 disables
		# response buffering so server-sent events arrive promptly.
		handle /api/* {
			reverse_proxy localhost:3000 {
				flush_interval -1
			}
		}

		# Everything else → the built SPA, with history-API fallback.
		handle {
			root * /home/ec2-user/hypergpt/dist/frontend

			# Content-hashed build assets are immutable — cache them hard.
			@immutable path /assets/*
			header @immutable Cache-Control "public, max-age=31536000, immutable"

			# The service worker, its registrar, the manifest, and the HTML
			# entry must always be revalidated, otherwise the browser keeps a
			# stale sw.js and never notices a new deploy. no-cache = revalidate
			# every time (not "don't store").
			@revalidate path /sw.js /registerSW.js /manifest.webmanifest /index.html /
			header @revalidate Cache-Control "no-cache"

			try_files {path} /index.html
			file_server
		}
	}
}
